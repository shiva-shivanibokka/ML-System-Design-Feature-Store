# Offline store (MotherDuck). Leave MOTHERDUCK_TOKEN empty for local DuckDB file.
MOTHERDUCK_TOKEN=
DUCKDB_DATABASE=feature_store
DUCKDB_PATH=feature_store.duckdb

# Online store (Redis-compatible — e.g. Aiven Valkey via its rediss:// URL).
# Leave default for local redis.
REDIS_URL=redis://localhost:6379

# Experiment tracking (DagsHub). Leave URI empty for local ./mlruns.
MLFLOW_TRACKING_URI=
MLFLOW_TRACKING_USERNAME=
MLFLOW_TRACKING_PASSWORD=

# Serving
ALLOWED_ORIGINS=*
FEATURE_VERSION=v1

# Frontend (Vercel) — set to the Cloud Run service URL in prod
NEXT_PUBLIC_API_URL=http://localhost:8080
